{
  "crons": [
    {
      "path": "/api/cron/create-payment-invoices",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/retry-failed-payments",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/check-overdue-payments",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/drain-outbox",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/process-email-queue",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/lesson-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/schedule-email-sends",
      "schedule": "*/5 * * * *"
    }
  ]
}
